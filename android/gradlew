#!/bin/bash
# Gradle Wrapper for systems without Gradle installed

GRADLE_VERSION="8.8"
GRADLE_DIR="$HOME/.gradle/wrapper/dists/gradle-$GRADLE_VERSION-bin"

if [ ! -f "$GRADLE_DIR/gradle-$GRADLE_VERSION/bin/gradle" ]; then
    echo "Downloading Gradle $GRADLE_VERSION..."
    mkdir -p "$GRADLE_DIR"
    cd "$GRADLE_DIR"
    curl -L "https://services.gradle.org/distributions/gradle-$GRADLE_VERSION-bin.zip" -o gradle.zip
    unzip -q gradle.zip
    rm gradle.zip
fi

exec "$GRADLE_DIR/gradle-$GRADLE_VERSION/bin/gradle" "$@"
